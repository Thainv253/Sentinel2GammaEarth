# ============================================
# Sentinel-2 Super Resolution Configuration
# ============================================
# Copy file này thành .env và điền thông tin:
#   cp .env.example .env

# ------ Google Cloud ------
# Project ID từ Google Cloud Console
# Hướng dẫn: https://console.cloud.google.com/
GCP_PROJECT_ID=your-gcp-project-id

# (Tùy chọn) Đường dẫn tới Service Account JSON key
# GEE_SERVICE_ACCOUNT_KEY=credentials/service-account.json

# ------ Khu vực quan tâm (AOI) ------
# Tọa độ trung tâm (WGS84)
LATITUDE=10.762622
LONGITUDE=106.660172

# Bán kính buffer (mét) - tạo bounding box xung quanh tọa độ
BUFFER_METERS=5000

# ------ Thời gian ------
# Khoảng thời gian tìm ảnh (YYYY-MM-DD)
START_DATE=2024-01-01
END_DATE=2024-06-01

# ------ Lọc mây ------
# Ngưỡng mây tối đa (%)
CLOUD_THRESHOLD=20

# ------ Môi trường chạy ------
# local  = chạy trực tiếp trên máy
# docker = chạy trong Docker container
# colab  = chạy trên Google Colab
RUNTIME_ENV=local

# ------ Device ------
# cpu = chạy trên CPU (chậm, không cần GPU NVIDIA)
# gpu = chạy trên GPU NVIDIA (nhanh, cần CUDA driver)
DEVICE=cpu
MEMORY_LIMIT=8g

# ------ Web Server ------
WEB_HOST=0.0.0.0
WEB_PORT=5000
WEB_DEBUG=true

# ------ Output ------
# Thư mục lưu dữ liệu
DATA_DIR=./data
OUTPUT_DIR=./output
# COLAB_OUTPUT_DIR=/content/output

# ------ Docker / Compute ------
# cpu = chạy trên CPU (chậm, không cần GPU)
# gpu = chạy trên GPU NVIDIA (nhanh, cần driver)
DEVICE=cpu

# Giới hạn RAM cho Docker (VD: 8g, 16g)
MEMORY_LIMIT=8g
